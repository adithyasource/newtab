{
  "manifest_version": 3,
  "name": "newtab",
  "description": "a boring browser extension for taking down notes",
  "version": "1.3",
  "permissions": ["identity", "storage"],
  "host_permissions": ["http://localhost:3000/*", "https://newtab.adithya.zip/*"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "/images/128.png",
    "48": "/images/128.png",
    "128": "/images/128.png"
  }
}
